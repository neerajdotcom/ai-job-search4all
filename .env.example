# Google Gemini (free tier — for resume optimization / writing)
# Get a free key at aistudio.google.com → Get API key
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (free tier — for high-volume job scoring)
# Get a free key at console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key_here

# Adzuna (free job search API — no credit card)
# Sign up at developer.adzuna.com to get both values
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here

# Gmail — use an App Password, not your regular Gmail password
# Guide: myaccount.google.com → Security → App Passwords
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your16charapppassword

# Who receives the daily digest
DIGEST_RECIPIENT=neerajbanerjee@gmail.com
